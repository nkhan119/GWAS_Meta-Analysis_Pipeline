// ================================================================
// nextflow.config — GWAS Meta-Analysis Pipeline CDC 1.0.0
// Author : Nadeem Khan, Bioinformatician, INRS-CAFSB
// GitHub : github.com/nkhan119
// ================================================================

manifest {
    name            = 'gwas-meta-pipeline'
    author          = 'Nadeem Khan, INRS-CAFSB'
    description     = 'Cross-cohort GWAS meta-analysis: harmonise → IVW/RE → annotate → report'
    version         = '1.0.0'
    nextflowVersion = '>=23.04'
    mainScript      = 'main.nf'
    homePage        = 'https://github.com/nkhan119'
}

// ── Parameters ─────────────────────────────────────────────────
params {

    // ── Input: point to your gwas-pipeline-v3 results ─────────
    base_dir     = "/home/nadeem/Downloads/1000G_phase3_common_norel"
    sumstats_dir = "${params.base_dir}/GWAS_analysis"   // contains Cohort_A/ Cohort_B/
    out_dir      = "${projectDir}/results"

    // ── Trait lists (must match gwas-pipeline-v3 output names) ─
    quant_traits  = "ldl_cholesterol,bmi,crp_log,height_cm"
    binary_traits = "cad,t2d,hypertension"

    // ── Meta-analysis method ───────────────────────────────────
    // Options: "ivw_re" | "ivw_fe" | "both"
    meta_method   = "ivw_re"

    // ── Filters ───────────────────────────────────────────────
    p_sig         = 5e-8        // genome-wide significance
    p_suggestive  = 1e-5        // suggestive loci
    i2_threshold  = 75          // Cochran I² % — flag high heterogeneity
    min_cohorts   = 2           // minimum cohorts a SNP must appear in

    // ── LD clumping for independent signals ───────────────────
    clump_p1      = 5e-8
    clump_p2      = 1e-2
    clump_r2      = 0.05
    clump_kb      = 500

    // ── Annotation ────────────────────────────────────────────
    // Reference genome build (GRCh37 or GRCh38)
    ref_build     = "GRCh37"

    // ── Skip flags ────────────────────────────────────────────
    skip_validate = false
    skip_annotate = false
    skip_figures  = false
    skip_report   = false

    // ── Report metadata ───────────────────────────────────────
    author      = "Nadeem Khan"
    institute   = "INRS-Centre Armand-Frappier Sante-Biotechnologie, Laval, QC, Canada"
    affiliation = "Bioinformatician"
    github      = "github.com/nkhan119"

    // ── Compute defaults ──────────────────────────────────────
    threads = 8
}

// ── Process defaults ───────────────────────────────────────────
process {
    errorStrategy = { task.exitStatus in [130,137,140] ? 'retry' : 'finish' }
    maxRetries    = 2

    withLabel: 'tiny'   { cpus = 2;  memory = { 4.GB  * task.attempt }; time = '30m' }
    withLabel: 'small'  { cpus = 4;  memory = { 8.GB  * task.attempt }; time = '2h'  }
    withLabel: 'medium' { cpus = 8;  memory = { 16.GB * task.attempt }; time = '4h'  }
    withLabel: 'large'  { cpus = 16; memory = { 32.GB * task.attempt }; time = '8h'  }

    withName: 'META_ANALYSIS'        { cpus = 8;  memory = { 16.GB * task.attempt }; time = '4h' }
    withName: 'ANNOTATION'           { cpus = 4;  memory = { 8.GB  * task.attempt }; time = '2h' }
    withName: 'META_FIGURES'         { cpus = 4;  memory = { 16.GB * task.attempt }; time = '2h';
                                       containerOptions = "-v ${projectDir}/bin:/opt/pipeline/bin" }
    withName: 'META_REPORT'          { cpus = 2;  memory = { 8.GB  * task.attempt }; time = '1h';
                                       containerOptions = "-v ${projectDir}/bin:/opt/pipeline/bin" }
}

// ── Profiles ───────────────────────────────────────────────────
profiles {

    // ── Local (Precision-5820-Tower / Ubuntu) ─────────────────
    local {
        process.executor = 'local'
        executor { cpus = 16; memory = '64 GB' }
        params.threads = 16
    }

    // ── Docker (local, reproducible) ──────────────────────────
    docker {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process.container = 'nkhan119/gwas-meta:1.0.0'
    }

    // ── Singularity (Narval / HPC) ────────────────────────────
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        process.container      = 'docker://nkhan119/gwas-meta:1.0.0'
    }

    // ── Conda (fallback) ─────────────────────────────────────
    conda {
        conda.enabled  = true
        conda.useMamba = false
        process.conda  = "${projectDir}/envs/meta_env.yaml"
    }

    // ── Narval — SLURM + Singularity ─────────────────────────
    narval {
        process.executor     = 'slurm'
        process.clusterOptions = '--account=def-fveyrier_cpu'
        singularity.enabled    = true
        singularity.autoMounts = true
        process.container      = 'docker://nkhan119/gwas-meta:1.0.0'

        executor {
            queueSize       = 150
            pollInterval    = '30 sec'
            submitRateLimit = '10/1min'
        }

        process {
            withLabel: 'tiny'   { queue = 'def-fveyrier_cpu'; time = '1h'  }
            withLabel: 'small'  { queue = 'def-fveyrier_cpu'; time = '4h'  }
            withLabel: 'medium' { queue = 'def-fveyrier_cpu'; time = '8h'  }
            withLabel: 'large'  { queue = 'def-fveyrier_cpu'; time = '16h' }
            withName: 'META_ANALYSIS'  { queue = 'def-fveyrier_cpu'; cpus = 16; memory = { 32.GB * task.attempt }; time = '8h'  }
            withName: 'META_FIGURES'   { queue = 'def-fveyrier_cpu'; cpus = 8;  memory = { 16.GB * task.attempt }; time = '4h'  }
        }

        params.threads = 32
        params.out_dir = "${projectDir}/results"
    }

    // ── Smoke test ────────────────────────────────────────────
    test {
        params.p_sig       = 5e-8
        params.min_cohorts = 2
        params.quant_traits = "ldl_cholesterol"
        params.binary_traits = "cad"
        process.memory = '8 GB'
        process.time   = '1h'
    }
}

// ── Execution reports ──────────────────────────────────────────
def ts = new java.text.SimpleDateFormat("yyyyMMdd_HHmm").format(new Date())
trace    { enabled = true; file = "${params.out_dir}/logs/trace_${ts}.txt";        overwrite = true; fields = 'task_id,name,status,exit,realtime,cpus,%cpu,memory,%mem,rss' }
report   { enabled = true; file = "${params.out_dir}/logs/nf_report_${ts}.html";   overwrite = true }
timeline { enabled = true; file = "${params.out_dir}/logs/timeline_${ts}.html";    overwrite = true }
dag      { enabled = true; file = "${params.out_dir}/logs/dag.svg";                overwrite = true }
